# LLM providers (通过 LiteLLM 统一)
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=

# LLM 精评用的默认模型（推荐 deepseek-chat 或 qwen-max，成本低）
JOB_RADAR_SCORER_MODEL=deepseek/deepseek-chat

# 推送渠道
# 首选 Resend（HTTPS API，免费 100 封/天，境内云主机也能发）
# 注册：https://resend.com/signup
RESEND_API_KEY=
# 若已在 Resend 验证自定义域名，把 SMTP_FROM 改为你的域名邮箱并设置：
RESEND_DOMAIN_VERIFIED=

# 备选：Gmail SMTP（本地机器可用，境内云主机可能被封）
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=            # Gmail App Password, https://myaccount.google.com/apppasswords
SMTP_FROM=
SMTP_TO=

# 可选：其他渠道（M2+ 支持）
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
GITHUB_TOKEN=
GITHUB_REPO=

# 成本硬上限（CNY / day），超限只跑硬规则档
JOB_RADAR_DAILY_LLM_BUDGET=5

# 日志级别
LOG_LEVEL=INFO
