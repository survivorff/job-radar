<!DOCTYPE html>
{% macro bar(label_en, label_zh, value) -%}
<div class="bar">
  <span class="bar-label">{{ label_en }} · {{ label_zh }}</span>
  <span class="bar-track"><span class="bar-fill" style="width: {{ value }}%"></span></span>
  <span class="bar-value">{{ value }}</span>
</div>
{%- endmacro %}
{% macro render_item(item) -%}
<div class="card {{ item.tier }}">
  <span class="score">{{ item.score }}</span>
  <div class="title">
    <a href="{{ item.apply_url }}">{{ item.company }} — {{ item.title }}</a>
    {% if item.dup_count > 0 %}<span class="dup">×{{ item.dup_count + 1 }}</span>{% endif %}
  </div>
  <div class="meta">
    <span class="loc">{{ item.location or "—" }}</span>
    {% if item.extra_locations %}<span class="extra-loc">+ {{ item.extra_locations | join(" / ") }}</span>{% endif %}
    {% if item.is_remote %}<span class="tag remote">remote · 远程</span>{% endif %}
    {% for t in item.matched_tracks %}<span class="tag track">{{ t }}</span>{% endfor %}
    {% if item.suggested_resume_version %}
      <span class="tag resume">resume {{ item.suggested_resume_version }}</span>
    {% endif %}
    <span class="tag src">{{ item.source }}{% if item.extra_sources %} +{{ item.extra_sources | length }}{% endif %}</span>
  </div>

  {% if item.explanation or item.explanation_zh %}
    <div class="summary">
      {% if item.explanation %}<div class="en">{{ item.explanation }}</div>{% endif %}
      {% if item.explanation_zh %}<div class="zh">{{ item.explanation_zh }}</div>{% endif %}
    </div>
  {% endif %}

  {% if item.dims %}
    <div class="bars">
      {{ bar("Tech", "技术栈", item.dims.get("tech_stack", 0)) }}
      {{ bar("Scenario", "场景", item.dims.get("scenario", 0)) }}
      {{ bar("Seniority", "职级", item.dims.get("seniority", 0)) }}
      {{ bar("Company", "公司", item.dims.get("company_fit", 0)) }}
    </div>
  {% endif %}

  {% if item.matched_keywords %}
    <div class="kw-row">
      <span class="kw-label">keywords · 命中关键词：</span>
      {% for kw in item.matched_keywords %}<span class="kw">{{ kw }}</span>{% endfor %}
    </div>
  {% endif %}

  {% if item.reasons or item.reasons_zh %}
    <div class="section">
      <div class="section-title">✓ Why · 为什么匹配</div>
      <div class="two-col">
        {% if item.reasons %}
        <ul class="en">{% for r in item.reasons %}<li>{{ r }}</li>{% endfor %}</ul>
        {% endif %}
        {% if item.reasons_zh %}
        <ul class="zh">{% for r in item.reasons_zh %}<li>{{ r }}</li>{% endfor %}</ul>
        {% endif %}
      </div>
    </div>
  {% endif %}

  {% if item.risks or item.risks_zh %}
    <div class="section">
      <div class="section-title risk">⚠ Verify · 需要验证</div>
      <div class="two-col">
        {% if item.risks %}
        <ul class="en risks">{% for r in item.risks %}<li>{{ r }}</li>{% endfor %}</ul>
        {% endif %}
        {% if item.risks_zh %}
        <ul class="zh risks">{% for r in item.risks_zh %}<li>{{ r }}</li>{% endfor %}</ul>
        {% endif %}
      </div>
    </div>
  {% endif %}
</div>
{%- endmacro %}
<html lang="en">
<head>
<meta charset="utf-8">
<title>Job Radar {{ d.kind }}</title>
<style>
  body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC",
         "Hiragino Sans GB", sans-serif; color: #1f2328; line-height: 1.55;
         padding: 16px; max-width: 820px; margin: 0 auto; font-size: 14px; }
  h1 { font-size: 22px; margin: 0 0 4px 0; }
  h2 { font-size: 16px; margin: 28px 0 10px 0; padding-bottom: 4px;
       border-bottom: 1px solid #eaeef2; }
  .muted { color: #6e7781; font-size: 12px; }
  .card { border: 1px solid #eaeef2; border-radius: 10px; padding: 14px 16px;
          margin: 12px 0; background: #fff; }
  .card.high { border-left: 4px solid #cf222e; }
  .card.med  { border-left: 4px solid #bf8700; }
  .card.low  { border-left: 4px solid #8250df; }
  .title { font-weight: 600; font-size: 15px; margin-bottom: 4px; }
  .title a { color: #1f2328; text-decoration: none; }
  .title a:hover { color: #0969da; text-decoration: underline; }
  .meta { font-size: 12px; color: #57606a; margin-bottom: 10px; }
  .loc { margin-right: 6px; }
  .score { float: right; font-weight: 700; font-size: 17px; color: #1f2328; }
  .tag { display: inline-block; background: #eaeef2; color: #1f2328;
         border-radius: 10px; padding: 1px 8px; font-size: 11px; margin-right: 4px; }
  .tag.remote { background: #ddf4ff; color: #0969da; }
  .tag.track  { background: #dafbe1; color: #116329; }
  .tag.resume { background: #fff8c5; color: #6d5600; }
  .tag.src    { background: #f6f8fa; color: #6e7781; font-weight: 400; }
  .dup        { display: inline-block; background: #fff8c5; color: #6d5600;
                border-radius: 10px; padding: 1px 8px; font-size: 11px; margin-left: 6px; }
  .extra-loc  { color: #6e7781; font-size: 11px; margin-right: 8px; }

  .summary { background: #f6f8fa; border-radius: 6px; padding: 8px 10px;
             margin: 8px 0 10px 0; font-size: 13px; }
  .summary .en { color: #1f2328; }
  .summary .zh { color: #57606a; margin-top: 2px; }

  .bars { display: grid; grid-template-columns: 1fr 1fr; gap: 4px 16px;
          margin: 10px 0 8px 0; }
  .bar { display: grid; grid-template-columns: 110px 1fr 28px;
         align-items: center; gap: 8px; font-size: 11px; }
  .bar-label { color: #57606a; }
  .bar-track { background: #eaeef2; height: 6px; border-radius: 3px; overflow: hidden; }
  .bar-fill { display: block; height: 100%; background: #1f883d; border-radius: 3px; }
  .bar-value { text-align: right; color: #57606a; font-variant-numeric: tabular-nums; }

  .kw-row { margin: 10px 0 4px 0; font-size: 12px; }
  .kw-label { color: #57606a; }
  .kw { display: inline-block; background: #f6f8fa; border: 1px solid #eaeef2;
        border-radius: 4px; padding: 1px 6px; font-size: 11px; margin: 2px 3px 0 0;
        font-family: ui-monospace, SFMono-Regular, monospace; color: #0969da; }

  .section { margin-top: 10px; padding-top: 6px; border-top: 1px dashed #eaeef2; }
  .section-title { font-size: 12px; font-weight: 600; color: #1f883d; margin-bottom: 4px; }
  .section-title.risk { color: #a40e26; }
  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 4px 16px; }
  .two-col ul { margin: 0; padding-left: 18px; font-size: 12.5px; }
  .two-col ul.en { color: #1f2328; }
  .two-col ul.zh { color: #57606a; }
  .two-col ul.risks.en { color: #a40e26; }
  .two-col ul.risks.zh { color: #9a3412; }

  @media (max-width: 560px) {
    .bars, .two-col { grid-template-columns: 1fr; }
  }

  details { margin-top: 16px; }
  summary { cursor: pointer; font-weight: 600; color: #57606a; font-size: 14px;
            padding: 6px 0; }
  hr.footer { margin-top: 32px; border: none; border-top: 1px solid #eaeef2; }
</style>
</head>
<body>
  <h1>Job Radar — {{ d.kind | capitalize }}{% if d.kind == "daily" %} · 日报{% else %} · 周报{% endif %}</h1>
  <div class="muted">
    {{ d.generated_at.strftime("%Y-%m-%d %H:%M UTC") }} · window {{ d.window_hours }}h ·
    new 新增 {{ d.total_new }} · scored 打分 {{ d.total_scored }} ·
    <b>{{ d.counts.high }}</b> high 高 ·
    <b>{{ d.counts.med }}</b> med 中 ·
    <b>{{ d.counts.low }}</b> low 候选
    {% if d.dedup_savings > 0 %}· merged 合并 {{ d.dedup_savings }}{% endif %}
  </div>

  {% if not d.has_content %}
    <p style="margin-top: 24px;">No matching JDs in this window. Radar is still watching.<br>
    <span class="muted">本周期内没有匹配的岗位，雷达仍在扫描。</span></p>
  {% endif %}

  {% if d.high %}
    <h2>🔴 High priority · 首投 ({{ d.high | length }})</h2>
    {% for item in d.high %}{{ render_item(item) }}{% endfor %}
  {% endif %}

  {% if d.med %}
    <h2>🟡 Medium · 精投 ({{ d.med | length }})</h2>
    {% for item in d.med %}{{ render_item(item) }}{% endfor %}
  {% endif %}

  {% if d.low %}
    <details>
      <summary>🟢 Candidates · 候选池 ({{ d.low | length }})</summary>
      {% for item in d.low %}{{ render_item(item) }}{% endfor %}
    </details>
  {% endif %}

  <hr class="footer">
  <div class="muted">
    Generated by <a href="https://github.com/survivorff/job-radar">job-radar</a> ·
    Scorer: heuristic (M1) · Sources: Lever / Greenhouse / Ashby<br>
    由 job-radar 自动生成 · 数据源：Lever / Greenhouse / Ashby
  </div>
</body>
</html>
